<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SRKupang</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="landing-home">
  <div class="landing-glow glow-a"></div>
  <div class="landing-glow glow-b"></div>

  <header class="site-header landing-header">
    <div>
      <h1>Sekolah Rendah OKAWSD Kupang, Tutong</h1>
      <p class="landing-subtitle">Reward, Student, Calendar and Leaderboard Hub</p>
    </div>
    <a class="admin-chip" href="/login/admin">Admin</a>
  </header>

  <main class="landing-shell">
    <section class="landing-card quick-access">
      <h2>Quick Access</h2>
      <p class="muted">Select a destination</p>

      <a class="landing-action teacher" href="/login/teacher">
        <span class="action-title">USER ID</span>
        <span class="action-desc">Manage rewards, students, reports</span>
      </a>

      <a class="landing-action leaderboard" href="/leaderboard">
        <span class="action-title">Leaderboard</span>
        <span class="action-desc">Display class rankings live</span>
      </a>
    </section>

    <section class="landing-card events-card">
      <div class="events-head">
        <h2>Upcoming Events</h2>
        <span class="events-range">Today + 7 days</span>
      </div>

      <% if (!events.length) { %>
        <div class="event-empty">No upcoming events.</div>
      <% } else { %>
        <div class="event-cards">
          <% events.forEach(event => { %>
            <article class="event-item">
              <div class="event-date"><%= event.event_date %></div>
              <div class="event-title"><%= event.title %></div>
              <% if (event.details) { %>
                <div class="event-detail"><%= event.details %></div>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>

