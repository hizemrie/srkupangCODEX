<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= cls.name %> Leaderboard</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="leaderboard-bg">
  <main class="leaderboard-screen leaderboard-v2 leaderboard-ref" id="leaderboardTable" data-class-id="<%= cls.id %>">
    <header class="leaderboard-titlebar">
      <span class="title-icon ring"></span>
      <h1>Leaderboard</h1>
      <button type="button" id="leaderboardMenuBtn" class="title-icon-btn" aria-label="Leaderboard menu" aria-expanded="false">
        <span class="title-icon menu"></span>
      </button>
    </header>

    <div class="leaderboard-sub center"><%= cls.name %></div>

    <div id="leaderboardMenuPanel" class="leaderboard-menu-panel hidden" role="menu">
      <button type="button" class="menu-item active" data-sort-mode="desc">Sort: Descending</button>
      <button type="button" class="menu-item" data-sort-mode="asc">Sort: Ascending</button>
      <a class="menu-link" href="/leaderboard">All Classes</a>
      <a class="menu-link" href="/">Home</a>
    </div>

    <section class="leaderboard-list-shell">
      <section class="leaderboard-podium" id="leaderboardPodium"></section>
      <div class="leaderboard-divider fancy"></div>
      <section class="leaderboard-list" id="leaderboardRows"></section>
      <div class="leaderboard-meta" id="lastUpdated">Last updated: <%= generatedAt %></div>
    </section>
  </main>

  <script id="leaderboardInitialRows" type="application/json"><%- JSON.stringify(rows) %></script>
  <script src="/js/leaderboard.js"></script>
</body>
</html>
