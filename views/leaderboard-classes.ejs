<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leaderboard Classes</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="leaderboard-bg">
  <header class="site-header leaderboard-header">
    <h1>Leaderboard</h1>
    <a class="btn secondary" href="/">Back to Home</a>
  </header>
  <main class="container leaderboard-class-shell">
    <p class="muted">Choose class to display live ranking.</p>
    <div class="leaderboard-class-grid">
      <% classes.forEach(cls => { %>
        <a class="leaderboard-class-card" href="/leaderboard/<%= cls.id %>"><%= cls.name %></a>
      <% }) %>
    </div>

    <section class="leaderboard-ref" style="margin-top:14px;">
      <div class="leaderboard-list-shell">
        <h3 style="margin:0 0 10px;">Whole School Top 10</h3>
        <% 
          function ordinal(rank) {
            const n = Number(rank || 0);
            const mod100 = n % 100;
            if (mod100 >= 11 && mod100 <= 13) return n + 'th';
            const mod10 = n % 10;
            if (mod10 === 1) return n + 'st';
            if (mod10 === 2) return n + 'nd';
            if (mod10 === 3) return n + 'rd';
            return n + 'th';
          }
          function shortDate(iso) {
            if (!iso) return '-';
            const d = new Date(iso);
            if (Number.isNaN(d.getTime())) return '-';
            return d.toLocaleDateString();
          }
        %>
        <% if (!schoolTop10 || !schoolTop10.length) { %>
          <div class="muted">No points data yet.</div>
        <% } %>
        <div class="leaderboard-list">
          <% (schoolTop10 || []).forEach((st, idx) => { 
               const photo = String(st.photo_url || '').trim() || ('https://api.dicebear.com/7.x/adventurer/svg?seed=' + encodeURIComponent(st.nickname || 'student'));
               const rank = idx + 1;
          %>
            <article class="leaderboard-row layout-ref rank-<%= rank <= 3 ? rank : 0 %>">
              <div class="row-left">
                <img class="avatar-photo" src="<%= photo %>" alt="<%= st.nickname %>" />
                <div class="name-block">
                  <div class="name-text"><%= st.nickname %></div>
                  <div class="points-text"><%= Number(st.total_points || 0).toLocaleString() %> points</div>
                </div>
              </div>
              <div class="row-mid">
                <div class="mid-line">Last awarded: <%= shortDate(st.last_awarded_at) %></div>
                <div class="mid-line">Reason: <%= st.last_reason || '-' %></div>
              </div>
              <div class="row-right">
                <span class="wreath-badge small clean"><%= ordinal(rank) %></span>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
